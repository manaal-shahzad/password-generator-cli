#challenge 6
import random
import string

pool = string.ascii_lowercase

contain_lowecase = True
contain_uppercase = True
contain_digits = True
contain_symbols = True

length = 16
password = ""
attempts = 0

if contain_uppercase:
        pool += string.ascii_uppercase
if contain_digits:
        pool += string.digits
if contain_symbols:
        pool += string.punctuation

for _ in range(length):
    password += random.choice(pool)

print("Password: ", password)

while True:
     attempts += 1
     candidate = ""
     for _ in range(length):
          candidate += random.choice(pool)
    
     has_upper = any(c.isupper() for c in candidate)
     has_digit = any(c.isdigit() for c in candidate)
     has_symbol = any(c in string.punctuation for c in candidate)
     if has_upper and has_digit and has_symbol:
          print(f"Passwod: ", candidate)
          print(f"Attempts: ", attempts)
          break